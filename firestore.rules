rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the user authenticated?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the requesting user an admin?
    // Requires a custom claim or a check against an admins collection.
    function isAdmin() {
      return isAuth() && request.auth.token.role == 'admin';
    }

    // ─── Public read collections ───────────────────────────────────────────

    // Blog posts — anyone can read, only admins can write
    match /blog-posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services — anyone can read, only admins can write
    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials — anyone can read, only admins can write
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FAQs — anyone can read, only admins can write
    match /faqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Privacy policy sections — anyone can read, only admins can write
    match /privacy-policy/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CMS pages (website content) — anyone can read, only admins can write
    match /cms-pages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Booking / Contact / Quote submissions ────────────────────────────

    // Bookings — anyone can create (public booking form), only auth users can read/update
    match /bookings/{docId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Contact enquiries
    match /contact-enquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Quote requests
    match /quote-requests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAuth();
    }

    // Quotations (generated by admins)
    match /quotations/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── User / Employee data ─────────────────────────────────────────────

    // Users — authenticated users can read/write their own doc; admins can read all
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Employees
    match /employees/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // HR records
    match /hr-records/{docId} {
      allow read, write: if isAdmin();
    }

    // Leave requests — employee creates, admin updates
    match /leave-requests/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isAdmin();
    }

    // Attendance
    match /attendance/{docId} {
      allow read, write: if isAuth();
    }

    // Payslips
    match /payslips/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Jobs / Products / Finance ────────────────────────────────────────

    match /jobs/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /products/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /finance/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── Surveys ─────────────────────────────────────────────────────────

    match /surveys/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /survey-responses/{docId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // ─── Meetings / Announcements / Notifications ─────────────────────────

    match /meetings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /notifications/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Messages / Chat ──────────────────────────────────────────────────

    match /messages/{docId} {
      allow read, write: if isAuth();
    }

    // ─── Fallback — deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
